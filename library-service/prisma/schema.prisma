generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Book {
  id              String   @id @default(uuid())
  title           String
  author          String
  isbn            String   @unique
  year            Int
  genre           String
  totalCopies     Int
  availableCopies Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("books")
}
